APP_NAME=Baymax
APP_ENV=local
DEBUG=True

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3:latest
